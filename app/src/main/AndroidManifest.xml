<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Notification permission (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Wake lock so the alarm fires even when screen is off -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Battery optimization exemption request -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Reschedule alarms after reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/medlogo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/medlogo"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartMedicationApp">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.SmartMedicationApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- WorkManager's internal foreground service -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!-- BroadcastReceiver: fires exact alarm to show notification -->
        <receiver
            android:name=".receiver.AlarmReceiver"
            android:exported="false" />

        <!-- BroadcastReceiver: "Mark as Taken" notification action -->
        <receiver
            android:name=".receiver.MarkAsTakenReceiver"
            android:exported="false" />

        <receiver
            android:name=".receiver.AlarmReceiver"
            android:exported="false" />

        <!-- BroadcastReceiver: reschedule on device boot -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>